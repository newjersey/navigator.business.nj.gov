{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "files": {
    "includes": [
      "**",
      "!**/.yarn/*",
      "!web/.next/*",
      "!package-lock.json",
      "!pnpm-lock.yaml",
      "!yarn.lock",
      "!bun.lockb",
      "!.claude"
    ]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100,
    "attributePosition": "auto",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "expand": "auto",
    "useEditorconfig": true,
    "includes": [
      "**",
      "!api/wiremock/__files/tax-clearance-success.json",
      "!**/docker-compose.yml",
      "!packages/static-site",
      "!**/.venv",
      "!**/venv"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "complexity": {
        "noForEach": "error",
        "useArrowFunction": "error",
        "useMaxParams": { "level": "error", "options": { "max": 4 } }
      },
      "correctness": { "noUnusedImports": "error", "noUnusedVariables": "error" },
      "nursery": {
        "noFloatingPromises": "off",
        "noNestedPromises": "error",
        "useErrorCause": "error"
      },
      "style": {
        "noCommonJs": "error",
        "noParameterAssign": "error",
        "useConst": "error",
        "useExportType": "error",
        "useImportType": "error",
        "useNodejsImportProtocol": "error",
        "useTemplate": "error",
        "useThrowOnlyError": "error"
      },
      "suspicious": {
        "noConsole": "error",
        "noExplicitAny": "error",
        "noImportCycles": "error",
        "noVar": "error"
      }
    },
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.venv",
      "!**/venv",
      "!**/aws_config_file_path.json",
      "!**/scripts/",
      "!**/.yarn",
      "!**/.vscode",
      "!**/coverage",
      "!content/lib",
      "!**/content",
      "!shared/lib",
      "!api/jspm_packages",
      "!api/.serverless",
      "!api/.webpack",
      "!api/src/setupTests.js",
      "!api/src/teardownTests.js",
      "!api/wiremock/__files/tax-clearance-success.json",
      "!api/cdk.out",
      "!api/lib/",
      "!api/dist/",
      "!api/cdk.context.json",
      "!api/node_modules",
      "!api/cdk/**/*.js",
      "!api/cdk/lib/**/*.js",
      "!api/cdk/bin/**/*.js",
      "!api/cdk/test/**/*.js",
      "!api/src/functions/messagingService/email-templates/",
      "!web/.next",
      "!**/amplify",
      "!**/*.md",
      "!web/public/",
      "!web/out_publish/",
      "!web/out_functions/",
      "!web/out/",
      "!web/cypress/plugins",
      "!web/cypress/support",
      "!web/stories",
      "!web/src/lib/cms/CollectionMap.json",
      "!web/amplify/#current-cloud-backend/",
      "!web/amplify/.config/local-*",
      "!web/amplify/logs",
      "!web/amplify/mock-data",
      "!web/amplify/backend/amplify-meta.json",
      "!web/amplify/backend/awscloudformation",
      "!web/amplify/backend/.temp",
      "!web/aws-exports.js",
      "!web/awsconfiguration.json",
      "!web/amplifyconfiguration.json",
      "!web/amplify-build-config.json",
      "!web/amplify-gradle-config.json",
      "!web/amplifytools.xcconfig",
      "!web/next-env.d.ts",
      "!packages/content-types",
      "!packages/static-site",
      "!packages/static-site/.next",
      "!packages/static-site/coverage",
      "!packages/static-site/playwright-report",
      "!packages/static-site/public/assets",
      "!packages/static-site/test-results"
    ]
  },
  "javascript": {
    "formatter": {
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSameLine": false,
      "quoteStyle": "double",
      "attributePosition": "auto",
      "bracketSpacing": true
    }
  },
  "html": { "formatter": { "indentScriptAndStyle": false, "selfCloseVoidElements": "always" } },
  "overrides": [
    { "includes": ["*.yml", "*.yaml"], "javascript": { "formatter": { "quoteStyle": "double" } } },
    { "includes": ["*.md"] }
  ],
  "assist": { "enabled": null, "actions": { "source": { "organizeImports": "on" } } }
}
