{
  "name": "@businessnjgovnavigator/static-site",
  "version": "0.0.1",
  "description": "Business.NJ.Gov is your first stop to plan, start, operate, and grow a business in the Garden State",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/newjersey/navigator.business.nj.gov.git",
    "directory": "packages/static-site"
  },
  "homepage": "https://next.business.nj.gov",
  "bugs": {
    "url": "https://github.com/newjersey/navigator.business.nj.gov/issues"
  },
  "scripts": {
    "predev": "pnpm sync:njwds-assets",
    "dev": "next dev -p 4000",
    "prebuild": "pnpm sync:njwds-assets",
    "build": "next build",
    "prestart": "pnpm sync:njwds-assets",
    "start": "next start",
    "clean": "rimraf .next coverage",
    "dependency-check": "node -e \"console.log('static-site dependency-check is not implemented yet')\"",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "spellcheck": "node -e \"console.log('static-site spellcheck is not implemented yet')\"",
    "typecheck": "tsc --noemit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:accessibility": "pnpm sync:njwds-assets",
    "sync:njwds-assets": "tsx scripts/syncNjwdsAssets.ts",
    "test:accessibility": "playwright test --config=playwright.a11y.config.ts",
    "pretest:e2e": "pnpm sync:njwds-assets",
    "test:e2e": "playwright test --config=playwright.e2e.config.ts",
    "pretest:e2e:english-only": "pnpm sync:njwds-assets",
    "test:e2e:english-only": "playwright test --config=playwright.e2e.english-only.config.ts",
    "test:e2e:all": "pnpm test:e2e && pnpm test:e2e:english-only"
  },
  "keywords": [],
  "author": {
    "name": "New Jersey Innovation Authority",
    "url": "https://github.com/newjersey"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.19.0",
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@biomejs/biome": "2.5.0",
    "@playwright/test": "1.61.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "axe-core": "4.12.1",
    "babel-plugin-react-compiler": "1.0.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.7",
    "playwright": "1.61.0",
    "playwright-core": "1.61.0",
    "rimraf": "6.1.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "@businessnjgovnavigator/content-types": "file:../content-types",
    "@newjersey/njwds": "2.9.1",
    "gray-matter": "^4.0.3",
    "next": "16.2.9",
    "next-intl": "4.13.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0"
  }
}
