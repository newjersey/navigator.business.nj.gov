# Runtime variables
# When "true", enables HTTP Basic Auth on the deployment
USE_BASIC_AUTH=
# Required when USE_BASIC_AUTH=true
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=

# Build-time variables (inlined by Next.js at build)
NEXT_PUBLIC_MULTILINGUAL_ENABLED=
NEXT_PUBLIC_SURVEY_MONKEY_ENABLED=
NEXT_PUBLIC_WEB_BASE_URL=
